{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "installCommand": "composer install --no-dev --prefer-dist --optimize-autoloader && npm ci --include=dev --ignore-scripts=false",
    "buildCommand": "npm run build",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "CACHE_STORE": "array",
        "LOG_CHANNEL": "stderr",
        "QUEUE_CONNECTION": "sync",
        "SESSION_DRIVER": "array",
        "VIEW_COMPILED_PATH": "/tmp/laravel-storage/framework/views",
        "APP_CONFIG_CACHE": "/tmp/laravel-storage/framework/cache/config.php",
        "APP_EVENTS_CACHE": "/tmp/laravel-storage/framework/cache/events.php",
        "APP_PACKAGES_CACHE": "/tmp/laravel-storage/framework/cache/packages.php",
        "APP_ROUTES_CACHE": "/tmp/laravel-storage/framework/cache/routes.php",
        "APP_SERVICES_CACHE": "/tmp/laravel-storage/framework/cache/services.php"
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*\\.(?:css|js|png|jpg|jpeg|gif|webp|avif|svg|ico|txt|pdf|woff|woff2|ttf|eot))",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
